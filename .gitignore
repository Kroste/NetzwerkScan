# ---- Build-Ausgaben ----
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
artifacts/

# ---- .NET / NuGet ----
project.lock.json
project.fragment.lock.json
*.nuget.props
*.nuget.targets
*.nupkg
*.snupkg
.packages/
# Falls NuGet-Pakete lokal abgelegt werden:
**/packages/*
!**/packages/build/

# ---- Visual Studio ----
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
*_i.c
*_p.c
*.ncb
*.aps
*.pch
*.vspscc
*.vssscc

# ---- JetBrains Rider ----
.idea/
*.sln.iml

# ---- Visual Studio Code ----
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ---- Test- / Coverage-Ergebnisse ----
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info
TestResults/

# ---- Roslyn / Build-Caches ----
*.cache
.cache/
*.tmp
*.tmp_proj
*.pidb
*.svclog
*.scc

# ---- ReSharper ----
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ---- Betriebssystem ----
.DS_Store
Thumbs.db
*~

# ---- Projektspezifisch (NetScanner) ----
# NLog schreibt nach %AppData%/~/.config – nicht ins Repo.
# Falls du internalLogFile o. Ä. ins Projekt umlenkst:
*.log
nlog-internal.log
