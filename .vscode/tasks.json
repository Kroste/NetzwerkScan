{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/NetScanner.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "clean",
      "command": "dotnet",
      "type": "process",
      "args": [ "clean", "${workspaceFolder}/NetScanner.csproj" ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "rebuild",
      "dependsOrder": "sequence",
      "dependsOn": [ "clean", "build" ],
      "problemMatcher": []
    },
    {
      // Loescht bin/ und obj/ wirklich vom Datentraeger — noetig, wenn die
      // vorkompilierte Avalonia-XAML im obj/-Cache haengt. Cross-platform.
      "label": "clean-hard",
      "type": "shell",
      "command": "rm -rf bin obj",
      "windows": {
        "command": "Remove-Item -Recurse -Force bin, obj -ErrorAction SilentlyContinue"
      },
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      // Liest die <Version> aus der csproj, taggt vX.Y.Z und pusht -> loest das
      // GitHub-Release aus. Interaktiv (Terminal sichtbar) fuer die Sicherheitsfragen;
      // fuer "ganz faul" das Skript direkt mit --yes / -Yes aufrufen.
      "label": "release (tag + push)",
      "type": "shell",
      "command": "bash scripts/release.sh",
      "windows": {
        "command": "pwsh -ExecutionPolicy Bypass -File scripts/release.ps1"
      },
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared", "focus": true },
      "problemMatcher": []
    }
  ]
}
