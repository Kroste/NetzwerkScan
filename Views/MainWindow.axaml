<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NetScanner.ViewModels"
        xmlns:models="using:NetScanner.Models"
        xmlns:ctrl="using:NetScanner.Controls"
        x:Class="NetScanner.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1180" Height="760" MinWidth="900" MinHeight="560"
        RequestedThemeVariant="Dark"
        Background="{StaticResource Bg}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        CanResize="True"
        Title="NetScanner — LAN &amp; Camera Discovery">

  <Window.Styles>
    <!-- Eingabefelder -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{StaticResource Bg}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
      <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
    </Style>
    <Style Selector="TextBox.mono">
      <Setter Property="FontFamily" Value="Cascadia Code,JetBrains Mono,Consolas,Menlo,monospace"/>
    </Style>

    <!-- Primaerbutton -->
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource Accent}"/>
      <Setter Property="Foreground" Value="#04201D"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="Padding" Value="18,0"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#4FCBBC"/>
      <Setter Property="Foreground" Value="#04201D"/>
    </Style>
    <Style Selector="Button.primary:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource Line}"/>
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
    </Style>

    <!-- Ghost-Button -->
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="Padding" Value="16,0"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <!-- Info-Button (rundes "i") -->
    <Style Selector="Button.info">
      <Setter Property="Background" Value="{StaticResource Surface}"/>
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="CornerRadius" Value="17"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.info:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
      <Setter Property="Foreground" Value="{StaticResource Accent}"/>
    </Style>

    <!-- Fenster-Steuerbuttons (Custom Chrome) -->
    <Style Selector="Button.win">
      <Setter Property="Width" Value="44"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="7"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.win:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
    </Style>
    <Style Selector="Button.win-close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#E0303F"/>
    </Style>

    <!-- Stream-Button (Kamera-Akzent) -->
    <Style Selector="Button.stream">
      <Setter Property="Background" Value="{StaticResource CameraSoft}"/>
      <Setter Property="Foreground" Value="{StaticResource Camera}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="7"/>
      <Setter Property="Padding" Value="12,6"/>
    </Style>
    <Style Selector="Button.stream:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource Camera}"/>
      <Setter Property="Foreground" Value="#1A0E04"/>
    </Style>

    <!-- Host-Karte: Hover -->
    <Style Selector="Border.host-card:pointerover">
      <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
    </Style>

    <!-- ListBox: Default-Item-Chrome entfernen, Karte uebernimmt die Optik -->
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="CornerRadius" Value="12"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBoxItem:selected Border.host-card">
      <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
      <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
    </Style>

    <!-- Port-Chip -->
    <Style Selector="Border.chip">
      <Setter Property="Background" Value="{StaticResource Bg}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="7,2"/>
      <Setter Property="Margin" Value="0,0,6,6"/>
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- ===== Kopfzeile / Custom-Titlebar ===== -->
    <!-- Background ist Pflicht: ohne ihn ist der Border nicht hit-testbar -> kein Drag. -->
    <Border Grid.Row="0" Padding="18,10,10,10" Background="{StaticResource Bg}"
            BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1"
            WindowDecorationProperties.ElementRole="TitleBar">
      <Grid ColumnDefinitions="*,Auto">

        <!-- Marke (hit-test-transparent -> Drag faellt auf die TitleBar-Region durch) -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="13" VerticalAlignment="Center"
                    IsHitTestVisible="False">
          <Panel Width="28" Height="28" VerticalAlignment="Center">
            <Ellipse Width="28" Height="28" Stroke="{StaticResource Accent}" StrokeThickness="1.5" Opacity="0.3"/>
            <Ellipse Width="19" Height="19" Stroke="{StaticResource Accent}" StrokeThickness="1.5" Opacity="0.6"/>
            <Ellipse Width="7"  Height="7"  Fill="{StaticResource Accent}"/>
          </Panel>
          <TextBlock Text="NetScanner" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
          <Border Background="{StaticResource Surface}" CornerRadius="5" Padding="7,3" VerticalAlignment="Center">
            <TextBlock Text="LAN · Ports · ONVIF/RTSP" FontSize="11"
                       Foreground="{StaticResource TextMuted}"/>
          </Border>
        </StackPanel>

        <!-- Stats + Aktionen + Fenstersteuerung -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center"
                      IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
              <TextBlock Text="{Binding HostCount}" FontSize="18" FontWeight="Bold"
                         Foreground="{StaticResource TextPrimary}"/>
              <TextBlock Text="Hosts" FontSize="13" VerticalAlignment="Center"
                         Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
              <TextBlock Text="{Binding CameraCount}" FontSize="18" FontWeight="Bold"
                         Foreground="{StaticResource Camera}"/>
              <TextBlock Text="Kameras" FontSize="13" VerticalAlignment="Center" Opacity="0.85"
                         Foreground="{StaticResource Camera}"/>
            </StackPanel>
          </StackPanel>

          <Border Width="1" Height="22" Background="{StaticResource Line}" IsHitTestVisible="False"/>

          <Border Width="1" Height="22" Background="{StaticResource Line}" IsHitTestVisible="False"/>

          <Button Classes="info" Click="OnMapClick" ToolTip.Tip="Netzwerkkarte"
                  WindowDecorationProperties.ElementRole="User">
            <Canvas Width="18" Height="18">
              <Line StartPoint="9,9" EndPoint="3.5,4.5" Stroke="{StaticResource TextMuted}" StrokeThickness="1.2"/>
              <Line StartPoint="9,9" EndPoint="14.5,5"  Stroke="{StaticResource TextMuted}" StrokeThickness="1.2"/>
              <Line StartPoint="9,9" EndPoint="9,15.5"  Stroke="{StaticResource TextMuted}" StrokeThickness="1.2"/>
              <Ellipse Canvas.Left="6"  Canvas.Top="6"  Width="6" Height="6" Fill="{StaticResource Accent}"/>
              <Ellipse Canvas.Left="1.5" Canvas.Top="2.5" Width="4" Height="4" Fill="{StaticResource TextMuted}"/>
              <Ellipse Canvas.Left="13" Canvas.Top="3"  Width="4" Height="4" Fill="{StaticResource TextMuted}"/>
              <Ellipse Canvas.Left="7"  Canvas.Top="14" Width="4" Height="4" Fill="{StaticResource TextMuted}"/>
            </Canvas>
          </Button>

          <Button Classes="info" Click="OnAboutClick" ToolTip.Tip="Information / Über"
                  WindowDecorationProperties.ElementRole="User">
            <TextBlock Text="i" FontFamily="Georgia,Cambria,serif" FontSize="16" FontWeight="Bold"/>
          </Button>

          <Border Width="1" Height="22" Background="{StaticResource Line}" IsHitTestVisible="False"/>

          <!-- Eigene Fenster-Buttons (ElementRole sorgt fuer natives Hit-Testing) -->
          <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
            <Button Classes="win" Click="OnMinimize" ToolTip.Tip="Minimieren"
                    WindowDecorationProperties.ElementRole="MinimizeButton">
              <Border Width="11" Height="1.4" Background="{StaticResource TextMuted}" VerticalAlignment="Center"/>
            </Button>
            <Button Classes="win" Click="OnMaximizeRestore" ToolTip.Tip="Maximieren"
                    WindowDecorationProperties.ElementRole="MaximizeButton">
              <Panel Width="12" Height="12">
                <Border x:Name="MaxGlyph" BorderBrush="{StaticResource TextMuted}"
                        BorderThickness="1.4" CornerRadius="2"/>
                <Panel x:Name="RestoreGlyph" IsVisible="False">
                  <Border Width="8" Height="8" BorderBrush="{StaticResource TextMuted}" BorderThickness="1.4"
                          CornerRadius="1.5" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                  <Border Width="8" Height="8" BorderBrush="{StaticResource TextMuted}" BorderThickness="1.4"
                          CornerRadius="1.5" Background="{StaticResource Bg}"
                          HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                </Panel>
              </Panel>
            </Button>
            <Button Classes="win win-close" Click="OnClose" ToolTip.Tip="Schließen"
                    WindowDecorationProperties.ElementRole="CloseButton">
              <Path Stroke="{StaticResource TextPrimary}" StrokeThickness="1.4"
                    Data="M0,0 L11,11 M0,11 L11,0"/>
            </Button>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===== Steuerleiste ===== -->
    <Border Grid.Row="1" Margin="20,16,20,0" Padding="16" CornerRadius="12"
            Background="{StaticResource Surface}">
      <StackPanel Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <StackPanel Spacing="4">
            <TextBlock Text="NETZBEREICH (CIDR)" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}"/>
            <TextBox Classes="mono" Text="{Binding Cidr}" Width="210" PlaceholderText="192.168.10.0/24"/>
          </StackPanel>
          <StackPanel Spacing="4">
            <TextBlock Text="ONVIF-WARTEZEIT (MS)" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}"/>
            <NumericUpDown Value="{Binding OnvifListenMs}" Minimum="500" Maximum="10000"
                           Increment="500" Width="130" Height="36"/>
          </StackPanel>
          <StackPanel Spacing="8" VerticalAlignment="Bottom" Margin="6,0,0,6">
            <CheckBox Content="Alle Ports (1–65535)" IsChecked="{Binding ScanFullPorts}"/>
            <CheckBox Content="RTSP prüfen" IsChecked="{Binding ProbeRtsp}"/>
          </StackPanel>
        </StackPanel>

        <Border Height="1" Background="{StaticResource Line}"/>

        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <StackPanel Spacing="4">
            <TextBlock Text="RTSP-LOGIN (OPTIONAL)" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox Text="{Binding RtspUser}" Width="150" PlaceholderText="Benutzer"/>
              <TextBox Text="{Binding RtspPass}" Width="150" PlaceholderText="Passwort" PasswordChar="•"/>
            </StackPanel>
          </StackPanel>

          <Button Classes="primary" Content="Scan starten" VerticalAlignment="Bottom"
                  Command="{Binding StartScanCommand}" IsEnabled="{Binding !IsScanning}"/>
          <Button Classes="ghost" Content="Abbrechen" VerticalAlignment="Bottom"
                  Command="{Binding CancelScanCommand}" IsEnabled="{Binding IsScanning}"/>
          <ProgressBar IsIndeterminate="{Binding IsScanning}" IsVisible="{Binding IsScanning}"
                       Width="160" Height="4" VerticalAlignment="Bottom" Margin="4,0,0,16"
                       Foreground="{StaticResource Accent}"/>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom" Margin="8,0,0,0">
            <Button Classes="ghost" Content="⬇ CSV" Click="OnExportCsv" ToolTip.Tip="Als CSV exportieren"/>
            <Button Classes="ghost" Content="⬇ JSON" Click="OnExportJson" ToolTip.Tip="Als JSON exportieren"/>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- ===== Inhalt: Liste | Video ===== -->
    <Grid Grid.Row="2" Margin="20,16,20,0" ColumnDefinitions="*,12,1.05*">

      <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled">
        <ListBox ItemsSource="{Binding Hosts}" SelectedItem="{Binding SelectedHost}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:HostResult">
              <Border Classes="host-card" Background="{StaticResource Surface}"
                      BorderBrush="{StaticResource Line}" BorderThickness="1"
                      CornerRadius="12" Padding="0"
                      PointerReleased="OnCardPointerReleased">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Im Browser öffnen" Click="OnHostWeb" IsVisible="{Binding HasWebUi}"/>
                    <MenuItem Header="SSH-Verbindung" Click="OnHostSsh" IsVisible="{Binding HasSsh}"/>
                    <MenuItem Header="Remotedesktop (RDP)" Click="OnHostRdp" IsVisible="{Binding HasRdp}"/>
                    <MenuItem Header="Dateifreigabe (SMB)" Click="OnHostSmb" IsVisible="{Binding HasSmb}"/>
                    <Separator/>
                    <MenuItem Header="IP kopieren" Click="OnHostCopyIp"/>
                    <MenuItem Header="MAC kopieren" Click="OnHostCopyMac" IsVisible="{Binding HasMac}"/>
                    <MenuItem Header="Name kopieren" Click="OnHostCopyName" IsVisible="{Binding HasBestName}"/>
                    <Separator/>
                    <MenuItem Header="Wake-on-LAN senden" Click="OnHostWol" IsVisible="{Binding HasMac}"/>
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid ColumnDefinitions="3,16,Auto,*,Auto">

                  <!-- Kamera-Akzentstreifen (Spalte immer 3px -> kein Layout-Shift) -->
                  <Border Grid.Column="0" Background="{StaticResource Camera}"
                          CornerRadius="12,0,0,12" IsVisible="{Binding IsCamera}"/>

                  <!-- Status-Punkt: Teal=ICMP, Gelb=nur ARP -->
                  <Panel Grid.Column="2" VerticalAlignment="Center" Width="12" Height="12">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource Online}"
                             IsVisible="{Binding IsIcmpAlive}"/>
                    <Ellipse Width="10" Height="10" Fill="{StaticResource ArpOnly}"
                             IsVisible="{Binding !IsIcmpAlive}"/>
                  </Panel>

                  <!-- Infoblock -->
                  <StackPanel Grid.Column="3" Spacing="5" Margin="14,12" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                      <TextBlock Text="{Binding Address}" FontWeight="Bold" FontSize="15"
                                 FontFamily="Cascadia Code,JetBrains Mono,Consolas,monospace"
                                 Foreground="{StaticResource TextPrimary}"/>
                      <Border Background="{StaticResource CameraSoft}" CornerRadius="4" Padding="6,1"
                              VerticalAlignment="Center" IsVisible="{Binding IsCamera}">
                        <TextBlock Text="KAMERA" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource Camera}"/>
                      </Border>
                      <TextBlock Text="{Binding Vendor}" FontSize="12" VerticalAlignment="Center"
                                 Foreground="{StaticResource TextMuted}"/>
                      <TextBlock Text="{Binding LatencyDisplay}" FontSize="11" VerticalAlignment="Center"
                                 Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>

                    <!-- Geraetetyp + OS -->
                    <Border Background="{StaticResource AccentSoft}" CornerRadius="4" Padding="7,2"
                            HorizontalAlignment="Left" IsVisible="{Binding HasDeviceInfo}">
                      <TextBlock Text="{Binding DeviceSummary}" FontSize="11" FontWeight="SemiBold"
                                 Foreground="{StaticResource Accent}"/>
                    </Border>

                    <TextBlock Text="{Binding BestName}" FontSize="12" IsVisible="{Binding HasBestName}"
                               Foreground="{StaticResource TextMuted}"/>

                    <TextBlock Text="{Binding DiscoveryDisplay}" FontSize="11" IsVisible="{Binding HasDiscovery}"
                               Foreground="{StaticResource Accent}" Opacity="0.85"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding BannerDisplay}" FontSize="11" IsVisible="{Binding HasBanner}"
                               FontFamily="Cascadia Code,Consolas,monospace"
                               Foreground="{StaticResource TextMuted}" Opacity="0.8"
                               TextTrimming="CharacterEllipsis"/>

                    <ItemsControl ItemsSource="{Binding OpenPorts}" Margin="0,2,0,0">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:PortResult">
                          <Border Classes="chip">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                              <TextBlock Text="{Binding Port}" FontSize="11" FontWeight="SemiBold"
                                         FontFamily="Cascadia Code,Consolas,monospace"
                                         Foreground="{StaticResource TextPrimary}"/>
                              <TextBlock Text="{Binding Service}" FontSize="11"
                                         Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding MacAddress}" FontSize="11" IsVisible="{Binding HasMac}"
                               FontFamily="Cascadia Code,Consolas,monospace"
                               Foreground="{StaticResource TextMuted}" Opacity="0.7"/>
                  </StackPanel>

                  <!-- Stream-Aktion -->
                  <Button Grid.Column="4" Classes="stream" Content="▶  Stream"
                          VerticalAlignment="Center" Margin="0,0,14,0"
                          IsVisible="{Binding IsCamera}"
                          Command="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).OpenStreamCommand}"
                          CommandParameter="{Binding}"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>

      <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns"/>

      <Grid Grid.Column="2" RowDefinitions="*,Auto">

        <!-- ===== Detail-Panel ===== -->
        <Border Grid.Row="0" CornerRadius="12" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Line}" BorderThickness="1" ClipToBounds="True">
          <Panel>
            <!-- Platzhalter -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10"
                        IsVisible="{Binding SelectedHost, Converter={x:Static ObjectConverters.IsNull}}">
              <Border Width="56" Height="56" CornerRadius="28" Background="{StaticResource SurfaceAlt}"
                      HorizontalAlignment="Center">
                <TextBlock Text="◉" FontSize="26" Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="Host auswählen für Details" Foreground="{StaticResource TextMuted}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Rechtsklick auf eine Karte für Aktionen" FontSize="12"
                         Foreground="{StaticResource TextMuted}" Opacity="0.6"
                         HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Detailinhalt -->
            <ScrollViewer IsVisible="{Binding SelectedHost, Converter={x:Static ObjectConverters.IsNotNull}}">
              <StackPanel DataContext="{Binding SelectedHost}" Margin="18" Spacing="13">

                <!-- Kopf: IP + Kamera-Badge -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="{Binding Address}" FontSize="20" FontWeight="Bold"
                             FontFamily="Cascadia Code,JetBrains Mono,Consolas,monospace"
                             Foreground="{StaticResource TextPrimary}"/>
                  <Border Background="{StaticResource CameraSoft}" CornerRadius="4" Padding="6,1"
                          VerticalAlignment="Center" IsVisible="{Binding IsCamera}">
                    <TextBlock Text="KAMERA" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource Camera}"/>
                  </Border>
                </StackPanel>

                <!-- Geraete-Badge -->
                <Border Background="{StaticResource AccentSoft}" CornerRadius="4" Padding="8,3"
                        HorizontalAlignment="Left" IsVisible="{Binding HasDeviceInfo}">
                  <TextBlock Text="{Binding DeviceSummary}" FontSize="12" FontWeight="SemiBold"
                             Foreground="{StaticResource Accent}"/>
                </Border>

                <!-- Aktionen -->
                <WrapPanel>
                  <Button Classes="ghost" Content="🌐 Web" Click="OnHostWeb" Margin="0,0,6,6"
                          IsVisible="{Binding HasWebUi}"/>
                  <Button Classes="ghost" Content="⌨ SSH" Click="OnHostSsh" Margin="0,0,6,6"
                          IsVisible="{Binding HasSsh}"/>
                  <Button Classes="ghost" Content="🖥 RDP" Click="OnHostRdp" Margin="0,0,6,6"
                          IsVisible="{Binding HasRdp}"/>
                  <Button Classes="ghost" Content="📁 SMB" Click="OnHostSmb" Margin="0,0,6,6"
                          IsVisible="{Binding HasSmb}"/>
                  <Button Classes="ghost" Content="⏻ Wake-on-LAN" Click="OnHostWol" Margin="0,0,6,6"
                          IsVisible="{Binding HasMac}"/>
                </WrapPanel>

                <Border Height="1" Background="{StaticResource Line}"/>

                <!-- Eigenschaften -->
                <StackPanel Spacing="7">
                  <Grid ColumnDefinitions="88,*" IsVisible="{Binding HasBestName}">
                    <TextBlock Grid.Column="0" Text="Name" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Grid.Column="1" Text="{Binding BestName}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextPrimary}"/>
                  </Grid>
                  <Grid ColumnDefinitions="88,*" IsVisible="{Binding Vendor, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Grid.Column="0" Text="Hersteller" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Vendor}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextPrimary}"/>
                  </Grid>
                  <Grid ColumnDefinitions="88,*" IsVisible="{Binding HasMac}">
                    <TextBlock Grid.Column="0" Text="MAC" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Grid.Column="1" Text="{Binding MacAddress}" FontSize="12"
                               FontFamily="Cascadia Code,Consolas,monospace"
                               Foreground="{StaticResource TextPrimary}"/>
                  </Grid>
                  <Grid ColumnDefinitions="88,*" IsVisible="{Binding Ttl, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Grid.Column="0" Text="TTL" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Ttl}" FontSize="12"
                               Foreground="{StaticResource TextPrimary}"/>
                  </Grid>
                  <Grid ColumnDefinitions="88,*">
                    <TextBlock Grid.Column="0" Text="Antwortzeit" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Grid.Column="1" Text="{Binding LatencyDisplay}" FontSize="12"
                               Foreground="{StaticResource TextPrimary}"/>
                  </Grid>
                </StackPanel>

                <!-- Discovery -->
                <StackPanel Spacing="7" IsVisible="{Binding HasDiscovery}">
                  <Border Height="1" Background="{StaticResource Line}"/>
                  <TextBlock Text="DISCOVERY" FontSize="10" FontWeight="SemiBold"
                             Foreground="{StaticResource TextMuted}"/>
                  <TextBlock Text="{Binding DiscoveryDisplay}" FontSize="12" TextWrapping="Wrap"
                             Foreground="{StaticResource Accent}"/>
                  <TextBlock Text="{Binding UpnpServer}" FontSize="11" TextWrapping="Wrap"
                             Foreground="{StaticResource TextMuted}"
                             IsVisible="{Binding UpnpServer, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>

                <!-- Banner -->
                <StackPanel Spacing="6" IsVisible="{Binding HasBanner}">
                  <Border Height="1" Background="{StaticResource Line}"/>
                  <TextBlock Text="{Binding BannerDisplay}" FontSize="11" TextWrapping="Wrap"
                             FontFamily="Cascadia Code,Consolas,monospace"
                             Foreground="{StaticResource TextMuted}"/>
                </StackPanel>

                <!-- Ports -->
                <StackPanel Spacing="7">
                  <Border Height="1" Background="{StaticResource Line}"/>
                  <TextBlock Text="OFFENE PORTS" FontSize="10" FontWeight="SemiBold"
                             Foreground="{StaticResource TextMuted}"/>
                  <ItemsControl ItemsSource="{Binding OpenPorts}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="models:PortResult">
                        <Border Classes="chip">
                          <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{Binding Port}" FontSize="11" FontWeight="SemiBold"
                                       FontFamily="Cascadia Code,Consolas,monospace"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="{Binding Service}" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>

                <!-- Kamera-Stream -->
                <StackPanel Spacing="8" IsVisible="{Binding IsCamera}">
                  <Border Height="1" Background="{StaticResource Line}"/>
                  <TextBlock Text="{Binding RtspUri}" FontSize="11" TextWrapping="Wrap"
                             FontFamily="Cascadia Code,Consolas,monospace"
                             Foreground="{StaticResource TextMuted}"
                             IsVisible="{Binding HasRtspUri}"/>
                  <Button Classes="stream" Content="▶  Stream öffnen" HorizontalAlignment="Left"
                          Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).OpenStreamCommand}"
                          CommandParameter="{Binding}"/>
                </StackPanel>

                <!-- Kopier-Aktionen -->
                <WrapPanel Margin="0,2,0,0">
                  <Button Classes="ghost" Content="IP kopieren" Click="OnHostCopyIp" Margin="0,0,6,6"/>
                  <Button Classes="ghost" Content="MAC kopieren" Click="OnHostCopyMac" Margin="0,0,6,6"
                          IsVisible="{Binding HasMac}"/>
                </WrapPanel>

              </StackPanel>
            </ScrollViewer>
          </Panel>
        </Border>

        <!-- ===== Video (nur bei aktivem Stream UND verfuegbarem libvlc) ===== -->
        <Border Grid.Row="1" Height="260" Margin="0,12,0,0" CornerRadius="12" Background="#05080B"
                BorderBrush="{StaticResource Line}" BorderThickness="1" ClipToBounds="True"
                IsVisible="{Binding ShowVideoPreview}">
          <ctrl:NativeVideoView MediaUrl="{Binding SelectedStreamUrl}"/>
        </Border>

        <!-- ===== Hinweis, wenn kein (passendes) VLC installiert ist ===== -->
        <Border Grid.Row="1" Height="260" Margin="0,12,0,0" CornerRadius="12" Background="#05080B"
                BorderBrush="{StaticResource Line}" BorderThickness="1" ClipToBounds="True"
                IsVisible="{Binding ShowVlcMissingHint}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" Margin="24">
            <TextBlock Text="Eingebettete Vorschau benötigt VLC"
                       Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="430"
                       Foreground="{StaticResource TextMuted}" FontSize="12"
                       Text="NetScanner bringt libvlc nicht mehr mit. Installiere den VLC media player (64-bit), dann läuft der Stream direkt hier. Ohne VLC kannst du die Stream-URL kopieren und extern öffnen."/>
            <Button Classes="stream" Content="VLC herunterladen" HorizontalAlignment="Center"
                    Click="OnDownloadVlc"/>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <!-- ===== Statusleiste ===== -->
    <Border Grid.Row="3" Padding="20,12" Margin="0,16,0,0"
            BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                 Fill="{StaticResource Accent}" IsVisible="{Binding IsScanning}"/>
        <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextMuted}"
                   FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"
                   VerticalAlignment="Center"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
