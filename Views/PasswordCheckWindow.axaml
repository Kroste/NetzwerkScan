<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NetScanner.Views.PasswordCheckWindow"
        Width="480" Height="560" MinWidth="420" MinHeight="520"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        RequestedThemeVariant="Dark"
        Background="{StaticResource Bg}"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="None"
        Title="Passwort-Leak-Check">

  <Window.Styles>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource Accent}"/>
      <Setter Property="Foreground" Value="#06201D"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Height" Value="44"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#4FCBBC"/>
      <Setter Property="Foreground" Value="#06201D"/>
    </Style>
    <Style Selector="Button.primary:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
    </Style>
    <Style Selector="Button.link">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource Accent}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="4,2"/>
    </Style>
    <Style Selector="Button.link:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="#4FCBBC"/>
    </Style>
    <Style Selector="Button.close">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Height" Value="38"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <!-- Fenster-Steuerbuttons (Custom Chrome) — identisch zum Hauptfenster -->
    <Style Selector="Button.win">
      <Setter Property="Width" Value="44"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="7"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.win:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
    </Style>
    <Style Selector="Button.win-close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#E0303F"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- ===== Custom-Titlebar ===== -->
    <Border Grid.Row="0" Padding="16,8,8,8" Background="{StaticResource Bg}"
            BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1"
            WindowDecorationProperties.ElementRole="TitleBar">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="11" VerticalAlignment="Center"
                    IsHitTestVisible="False">
          <Panel Width="24" Height="24" VerticalAlignment="Center">
            <Ellipse Width="24" Height="24" Stroke="{StaticResource Accent}" StrokeThickness="1.5" Opacity="0.3"/>
            <Ellipse Width="16" Height="16" Stroke="{StaticResource Accent}" StrokeThickness="1.5" Opacity="0.6"/>
            <Ellipse Width="6"  Height="6"  Fill="{StaticResource Accent}"/>
          </Panel>
          <TextBlock Text="NetScanner" FontSize="15" FontWeight="Bold"
                     Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
          <Border Background="{StaticResource Surface}" CornerRadius="5" Padding="6,2" VerticalAlignment="Center">
            <TextBlock Text="Passwort-Check" FontSize="10" Foreground="{StaticResource TextMuted}"/>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
          <Button Classes="win" Click="OnMinimize" ToolTip.Tip="Minimieren"
                  WindowDecorationProperties.ElementRole="MinimizeButton">
            <Border Width="11" Height="1.4" Background="{StaticResource TextMuted}" VerticalAlignment="Center"/>
          </Button>
          <Button Classes="win" Click="OnMaximizeRestore" ToolTip.Tip="Maximieren"
                  WindowDecorationProperties.ElementRole="MaximizeButton">
            <Panel Width="12" Height="12">
              <Border x:Name="MaxGlyph" BorderBrush="{StaticResource TextMuted}"
                      BorderThickness="1.4" CornerRadius="2"/>
              <Panel x:Name="RestoreGlyph" IsVisible="False">
                <Border Width="8" Height="8" BorderBrush="{StaticResource TextMuted}" BorderThickness="1.4"
                        CornerRadius="1.5" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                <Border Width="8" Height="8" BorderBrush="{StaticResource TextMuted}" BorderThickness="1.4"
                        CornerRadius="1.5" Background="{StaticResource Bg}"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
              </Panel>
            </Panel>
          </Button>
          <Button Classes="win win-close" Click="OnClose" ToolTip.Tip="Schließen"
                  WindowDecorationProperties.ElementRole="CloseButton">
            <Path Stroke="{StaticResource TextPrimary}" StrokeThickness="1.4"
                  Data="M0,0 L11,11 M0,11 L11,0"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===== Inhalt ===== -->
    <StackPanel Grid.Row="1" Margin="28,22,28,24" Spacing="16">

      <StackPanel Spacing="4">
        <TextBlock Text="Passwort gegen Leaks prüfen" FontSize="19" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}"/>
        <TextBlock Text="Steht das Passwort deiner Kamera, deines Routers oder eines anderen Geräts in bekannten Daten-Leaks?"
                   FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource TextMuted}"/>
      </StackPanel>

      <!-- Datenschutz-/Transparenzhinweis -->
      <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}"
              BorderThickness="1" CornerRadius="10" Padding="14,12">
        <StackPanel Spacing="7">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <TextBlock Text="🔒" FontSize="13"/>
            <TextBlock Text="Dein Passwort verlässt dieses Gerät nicht" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="17"
                     Foreground="{StaticResource TextMuted}"
                     Text="Geprüft wird per k-Anonymity gegen die Pwned-Passwords-Datenbank von Have I Been Pwned. Es werden nur die ersten 5 Zeichen des SHA-1-Hashes übertragen — niemals das Passwort und niemals der vollständige Hash. Der Abgleich passiert lokal. Dasselbe Verfahren nutzen Bitwarden, 1Password und Firefox."/>
        </StackPanel>
      </Border>

      <!-- Eingabe -->
      <StackPanel Spacing="8">
        <TextBlock Text="PASSWORT" FontSize="10" FontWeight="SemiBold"
                   Foreground="{StaticResource TextMuted}"/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <TextBox x:Name="PwBox" Grid.Column="0" PasswordChar="•" Height="42"
                   FontSize="14" PlaceholderText="Zu prüfendes Passwort eingeben"
                   KeyDown="OnPwKeyDown"/>
          <ToggleButton x:Name="RevealToggle" Grid.Column="1" Content="👁" Width="46" Height="42"
                        FontSize="15" ToolTip.Tip="Passwort anzeigen"
                        IsCheckedChanged="OnRevealChanged"/>
        </Grid>
      </StackPanel>

      <Button x:Name="CheckBtn" Classes="primary" Content="Prüfen" Click="OnCheckClick"/>

      <!-- Passwortstärke (lokal, sofort) -->
      <Border x:Name="StrengthBox" IsVisible="False" Background="{StaticResource Surface}"
              BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="10" Padding="14,12">
        <StackPanel Spacing="9">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Passwortstärke" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
            <TextBlock x:Name="StrengthLabel" Grid.Column="1" FontSize="12" FontWeight="Bold"/>
          </Grid>
          <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="4" Height="6">
            <Border x:Name="Seg0" Grid.Column="0" CornerRadius="3" Background="{StaticResource Line}"/>
            <Border x:Name="Seg1" Grid.Column="1" CornerRadius="3" Background="{StaticResource Line}"/>
            <Border x:Name="Seg2" Grid.Column="2" CornerRadius="3" Background="{StaticResource Line}"/>
            <Border x:Name="Seg3" Grid.Column="3" CornerRadius="3" Background="{StaticResource Line}"/>
            <Border x:Name="Seg4" Grid.Column="4" CornerRadius="3" Background="{StaticResource Line}"/>
          </Grid>
          <StackPanel Spacing="3" Margin="0,2,0,0">
            <TextBlock x:Name="CrackFast" FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock x:Name="CrackSlow" FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource TextMuted}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Ergebnis Leak-Check -->
      <Border x:Name="ResultBox" IsVisible="False" BorderThickness="1" CornerRadius="10" Padding="14,12">
        <StackPanel Spacing="4">
          <TextBlock x:Name="ResultTitle" FontSize="14" FontWeight="Bold" TextWrapping="Wrap"/>
          <TextBlock x:Name="ResultDetail" FontSize="12" TextWrapping="Wrap"
                     Foreground="{StaticResource TextMuted}"/>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
        <TextBlock Text="Datenquelle:" FontSize="11" Foreground="{StaticResource TextMuted}"
                   VerticalAlignment="Center"/>
        <Button Classes="link" Content="haveibeenpwned.com/Passwords" Click="OnHibpClick"/>
      </StackPanel>

      <Button Classes="close" Content="Schließen" Click="OnCloseClick"/>
    </StackPanel>
  </Grid>
</Window>
