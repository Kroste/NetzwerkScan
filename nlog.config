<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="${specialfolder:folder=ApplicationData}/NetScanner/nlog-internal.log">

  <!-- Zielverzeichnis: %AppData%/NetScanner/logs unter Windows,
       ~/.config/NetScanner/logs unter Linux (specialfolder=ApplicationData). -->
  <variable name="logDir" value="${specialfolder:folder=ApplicationData}/NetScanner/logs" />
  <variable name="layout"
            value="${longdate}|${level:uppercase=true:padding=-5}|${logger:shortName=true}|${message}${onexception:${newline}${exception:format=tostring}}" />

  <targets>
    <!-- Alles in eine rollende Tagesdatei -->
    <target xsi:type="File" name="file"
            fileName="${logDir}/netscanner-${shortdate}.log"
            layout="${layout}"
            keepFileOpen="true"
            concurrentWrites="true"
            archiveAboveSize="10485760"
            maxArchiveFiles="14"
            encoding="utf-8" />

    <!-- Separates, leicht auswertbares Audit-Log NUR fuer Benutzereingaben -->
    <target xsi:type="File" name="audit"
            fileName="${logDir}/userinput-${shortdate}.log"
            layout="${longdate}|${message}"
            encoding="utf-8" />

    <target xsi:type="Console" name="console"
            layout="${time}|${level:uppercase=true:padding=-5}|${logger:shortName=true}|${message}" />
  </targets>

  <rules>
    <!-- Der Logger "UserInput" geht zusaetzlich ins Audit-Log und wird dort nicht weitergereicht-doppelt.
         final=false: laeuft danach weiter in die normalen Regeln. -->
    <logger name="UserInput" minlevel="Info" writeTo="audit" final="false" />

    <!-- Microsoft/Avalonia-Rauschen daempfen -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="Avalonia.*" maxlevel="Info" final="true" />

    <!-- Standard: alles ab Debug in Datei + Konsole -->
    <logger name="*" minlevel="Debug" writeTo="file,console" />
  </rules>
</nlog>
