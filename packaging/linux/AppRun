#!/bin/bash
# Einstiegspunkt der AppImage. $APPDIR zeigt auf das entpackte Image.
HERE="$(dirname "$(readlink -f "${0}")")"
APP="${HERE}/usr/bin"

# Falls libvlc + Plugins mitgebündelt wurden (siehe build-appimage.sh, optionaler Block),
# diese bevorzugen — sonst wird die System-libvlc verwendet.
if [ -d "${APP}/libvlc" ]; then
    export LD_LIBRARY_PATH="${APP}/libvlc:${LD_LIBRARY_PATH}"
    export VLC_PLUGIN_PATH="${APP}/libvlc/plugins"
fi

exec "${APP}/NetScanner" "$@"
